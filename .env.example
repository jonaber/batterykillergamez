# Battery Killer Gamez — environment template.
# Copy this file to `.env` and fill in real values:
#   cp .env.example .env
# config.php reads `.env`; any key left out falls back to the stock-XAMPP
# defaults, so a local install works even with no `.env` present.

# ── Database connection ──
DB_HOST=127.0.0.1
DB_NAME=batterykillergamez
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ── First-admin seed ──
# Only used to create the initial admin account on first setup. Change these
# before exposing the site, then manage logins under Admin → Users.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# ── Email / SMTP (contact form, sent via PHPMailer) ──
# Set MAIL_ENABLED=true and fill in your SMTP details to turn on sending.
# MAIL_ENCRYPTION: tls (port 587) | ssl (port 465) | none
# Example (Gmail): MAIL_HOST=smtp.gmail.com, MAIL_PORT=587, MAIL_ENCRYPTION=tls,
#   MAIL_USERNAME=you@gmail.com, MAIL_PASSWORD=<app password, not your login>.
MAIL_ENABLED=false
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=Battery Killer Gamez
# Inbox that receives contact-form submissions.
MAIL_TO_ADDRESS=

# Contact-form confirmation copy / site label.
SITE_NAME=Battery Killer Gamez
